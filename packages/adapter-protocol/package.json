  "publishConfig": { "access": "public" },
  "engines": { "node": ">=22 <27" },
  "scripts": { "build": "tsc -b", "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"", "typecheck": "tsc -b --pretty false", "test": "vitest run" },
  "dependencies": { "@discord-verify/shared": "workspace:*" }
}
