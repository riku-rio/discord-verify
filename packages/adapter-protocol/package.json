{
  "name": "@discord-verify/adapter-protocol",
  "version": "0.1.0",
  "description": "Versioned contracts shared by adapter workers and the core.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
