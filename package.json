{
  "name": "discord-verify",
  "version": "0.0.0",
  "private": true,
  "description": "CLI-first verification framework for Discord bots",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --pretty false",
    "pack:check": "node -e \"require('node:fs').mkdirSync('artifacts/packages',{recursive:true})\" && pnpm --filter \"./packages/**\" pack --pack-destination artifacts/packages",
    "check:python": "uv run ruff check python tests/python && uv run mypy python && uv run pytest"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.31.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  },
  "type": "module"
}
