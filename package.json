{
  "name": "discord-verify-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Engineering workspace for Discord Verify.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": { "node": ">=22 <27", "pnpm": ">=11 <12" },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit --pretty false",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare:artifacts": "node -e \"require('node:fs').mkdirSync('.artifacts',{recursive:true})\"",
    "test:python": "pnpm run prepare:artifacts && python -m pytest packages/adapter-discordpy/python",
    "lint:python": "ruff check packages/adapter-discordpy/python",
    "format:python": "ruff format packages/adapter-discordpy/python",
    "format:python:check": "ruff format --check packages/adapter-discordpy/python",
    "typecheck:python": "mypy packages/adapter-discordpy/python/src",
    "check:python": "pnpm run lint:python && pnpm run format:python:check && pnpm run typecheck:python && pnpm run test:python",
    "check:repository": "node scripts/validate-repository.mjs",
    "pack:check": "node scripts/validate-package-contents.mjs",
    "check": "pnpm run prepare:artifacts && pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run typecheck:tests && pnpm run test:coverage && pnpm run check:python && pnpm run check:repository && pnpm run build && pnpm run pack:check",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "9.39.5",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
